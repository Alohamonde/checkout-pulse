generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model OfferRule {
  id                    String   @id @default(cuid())
  shop                  String
  enabled               Boolean  @default(true)
  triggerType           String   @default("product")
  triggerProductId      String   @default("")
  triggerProductTitle   String   @default("")
  triggerCollectionId   String   @default("")
  triggerCollectionTitle String  @default("")
  minOrderAmount        Float    @default(0)
  offerProductId        String
  offerProductTitle     String
  offerVariantId        String
  discountPercent       Float    @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([shop])
}

model OfferEvent {
  id        String   @id @default(cuid())
  shop      String
  ruleId    String?
  eventType String
  orderId   String?
  createdAt DateTime @default(now())

  @@index([shop, eventType])
  @@index([shop, ruleId])
}
